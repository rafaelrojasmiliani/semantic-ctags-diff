# EditorConfig: https://editorconfig.org
# Keeps indentation and basic style consistent across editors and IDEs.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 140

[*.py]
indent_style = space
indent_size = 4

[*.{toml,yml,yaml,json,md}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
